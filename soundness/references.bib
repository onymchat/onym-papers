@misc{eth-kzg-ceremony,
  author       = {{Ethereum Foundation} and {KZG Ceremony Contributors}},
  title        = {{KZG} Summoning Ceremony},
  year         = 2023,
  howpublished = {\url{https://ceremony.ethereum.org/} and
                  \url{https://github.com/ethereum/kzg-ceremony}},
  note         = {Multi-party trusted setup ceremony for the BLS12-381
                  KZG SRS used by Ethereum's EIP-4844 blob commitments.
                  Final transcript records $\sim$141{,}000 contributors
                  over Aug 2022 -- Nov 2023 (main contributor phase
                  Jan 2023 -- Mar 2023). The same SRS is reused at
                  Lagrange-basis cuts up to size $2^{28}$ by BLS12-381-
                  targeted PLONK and Halo2 deployments.}
}

