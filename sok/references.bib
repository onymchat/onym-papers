% ─── §3, §5, §6, §7, §8 host functions and chain protocol upgrades ───

% Verified 2026-04-29 against the stellar-protocol repository and
% the cap-0059.md / cap-0074.md / cap-0075.md source files. Earlier
% drafts of this paper used the wrong CAP number (0058 → 0059); the
% wrong number is no longer cited anywhere in the source tree.

@misc{stellar-cap-0059,
  author       = {Jay Geng},
  title        = {{CAP-0059}: Host functions for {BLS12-381}},
  year         = 2024,
  howpublished = {Stellar Core Advancement Proposal, Final},
  note         = {\url{https://github.com/stellar/stellar-protocol/blob/master/core/cap-0059.md}.
                  Activated in Stellar Protocol 22. Adds 16 host
                  functions across $\mathbb{G}_1$, $\mathbb{G}_2$,
                  $\mathbb{F}_r$ scalar arithmetic, hash-to-curve, and
                  the multi-pairing check that {C1} ($R_{\mathsf{Upd}}$
                  verifier) reduces to.}
}

@misc{stellar-cap-0074,
  author       = {{Stellar Development Foundation}},
  title        = {{CAP-0074}: Host functions for {BN254}},
  year         = 2025,
  howpublished = {Stellar Core Advancement Proposal, Final},
  note         = {\url{https://github.com/stellar/stellar-protocol/blob/master/core/cap-0074.md}.
                  Activated in Stellar Protocol 25. Adds {BN254} G1
                  point addition, scalar multiplication, and pairing
                  check. Materially changes the migration cost of
                  C2-on-Stellar (\S\ref{sec:mig-c2}).}
}

@misc{stellar-cap-0075,
  author       = {{Stellar Development Foundation}},
  title        = {{CAP-0075}: Cryptographic Primitives for
                  {P}oseidon and {P}oseidon2 Hash Functions},
  year         = 2025,
  howpublished = {Stellar Core Advancement Proposal, Final},
  note         = {\url{https://github.com/stellar/stellar-protocol/blob/master/core/cap-0075.md}.
                  Activated in Stellar Protocol 25. Adds {P}oseidon
                  and {P}oseidon2 \emph{permutation} primitives over
                  {BLS12-381} $\mathbb{F}_r$ and {BN254}
                  $\mathbb{F}_r$. The {CAP}'s rationale explicitly
                  scopes \emph{out} {NTT}, {G}oldilocks-field
                  arithmetic, and {FRI}-related primitives; this is
                  the load-bearing host-function gap for the C7 row
                  in \S\ref{sec:cfg-c7} and \S\ref{sec:mig-c7}.}
}

% ─── §5 C1 trusted-setup provenance (EF KZG ceremony) ───────────────

@misc{eth-kzg-ceremony,
  author       = {{Ethereum Foundation} and {KZG Ceremony Contributors}},
  title        = {{KZG} Summoning Ceremony},
  year         = 2023,
  howpublished = {\url{https://ceremony.ethereum.org/} and
                  \url{https://github.com/ethereum/kzg-ceremony}},
  note         = {Multi-party trusted setup ceremony for the BLS12-381
                  KZG SRS used by Ethereum's EIP-4844 blob commitments.
                  Final transcript records ${\sim}141{,}000$
                  contributors over the broader Aug 2022 -- Nov 2023
                  window (main contributor phase
                  Jan 2023 -- Mar 2023). The same SRS is reused at
                  Lagrange-basis cuts up to size $2^{28}$ by BLS12-381-
                  targeted PLONK and Halo2 deployments. Cited as the
                  trusted-setup parameter source for C1
                  (\S\ref{sec:cfg-c1}). TODO: pin a stable transcript
                  URL or IPFS CID at submission time; the
                  \texttt{ceremony.ethereum.org} CDN is not authoritative.}
}

